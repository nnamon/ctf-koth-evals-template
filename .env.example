# Shared password that gates the human UI / public /api/* endpoints.
# Generate with: openssl rand -hex 16
CTF_EVALS_PASSWORD=changeme

# Bearer token workers use to authenticate against /internal/*.
# Distinct from the user password so a compromised worker can't pose as a user.
# Generate with: openssl rand -hex 32
CTF_EVALS_WORKER_TOKEN=changeme-too

# Optional: host port to expose serve on (default 8080).
# CTF_EVALS_PORT=8080
